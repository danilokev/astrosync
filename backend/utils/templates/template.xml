<star>
  <name>{{title}}</name>
  <image>{{imageUrl}}</image>
  {{#if attributionRequired}}
  <image-attribution>
    {{#if artistText}}
    <text>{{artistText}}</text>
    {{/if}}

    {{#if artistName}}
    <artist>
      <name>{{artistName}}</name>
      {{#if artistProfileUrl}}
      <profileUrl>{{artistProfileUrl}}</profileUrl>
      {{/if}}
    </artist>
    {{/if}}

    {{#if license}}
    <license>
      <name>{{license}}</name>
      {{#if licenseUrl}}
      <url>{{licenseUrl}}</url>
      {{/if}}
    </license>
    {{/if}}

    {{#if wikimediaUrl}}
    <source>
      <name>Wikimedia Commons</name>
      <url>{{wikimediaUrl}}</url>
    </source>
    {{/if}}
  </image-attribution>
  {{/if}}
  <description>{{description}}</description>
  <wikipediaUrl>{{articleUrl}}</wikipediaUrl>
